# Microsoft Purview Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit .env to source control

# Required: Your Purview account name (e.g., "my-purview-account")
PURVIEW_ACCOUNT_NAME=your-purview-account-name

# Optional: Specific table details for testing
TABLE_NAME=your-table-name
WORKSPACE_NAME=your-workspace-name
LAKEHOUSE_NAME=your-lakehouse-name

# Optional: If using service principal authentication
# AZURE_TENANT_ID=your-tenant-id
# AZURE_CLIENT_ID=your-client-id
# AZURE_CLIENT_SECRET=your-client-secret
